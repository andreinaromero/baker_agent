# ==============================================================================
# CONFIGURACIÓN DEL AGENTE REPOSTERO - VARIABLES DE ENTORNO
# Copia este archivo como '.env' y completa con tus credenciales.
# ==============================================================================

# --- CONFIGURACIÓN GENERAL ---
APP_ENV=development
CHROMA_DB_DIR=./chroma_db

# --- CONFIGURACIÓN DE EMBEDDINGS Y LLM ---
# Opciones de Vector/Embedding: 'huggingface' (local) o 'openai' (nube)
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Local Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=llama3

# Si usas OpenAI (descomenta y completa):
# OPENAI_API_KEY=tu_api_key_aqui
# OPENAI_MODEL_NAME=gpt-4o-mini

# --- FUENTES DE DATOS: GOOGLE DRIVE ---
# Ruta local al archivo JSON de credenciales de Google (generado en Google Cloud Console)
GOOGLE_CREDENTIALS_FILE=data/credentials/credentials.json
# Ruta donde se almacenará el token de usuario tras la autenticación inicial
GOOGLE_TOKEN_FILE=data/credentials/token.json
# ID de la carpeta de Google Drive donde tienes tus recetas en PDF
GOOGLE_DRIVE_FOLDER_ID=tu_folder_id_de_google_drive_aqui

# --- FUENTES DE DATOS: DROPBOX ---
# Token de acceso de Dropbox (Access Token)
DROPBOX_ACCESS_TOKEN=tu_access_token_de_dropbox_aqui
# Opcional (recomendado para tokens de larga duración):
DROPBOX_APP_KEY=tu_app_key_aqui
DROPBOX_APP_SECRET=tu_app_secret_aqui
DROPBOX_REFRESH_TOKEN=tu_refresh_token_aqui
# Ruta de la carpeta en Dropbox a procesar (ej: /recetas o /)
DROPBOX_FOLDER_PATH=/recetas
